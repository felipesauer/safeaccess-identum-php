{
    "name": "safeaccess/identum",
    "version": "0.1.3",
    "description": "Brazilian document validation library (CPF, CNPJ, CEP, CNH, CNS, PIS, IE, RENAVAM, Voter Title, Mercosul Plate)",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "safeaccess",
        "identum",
        "validation",
        "document",
        "cpf",
        "cnpj",
        "brazilian"
    ],
    "homepage": "https://github.com/felipesauer/safeaccess-identum",
    "authors": [
        {
            "name": "Felipe Sauer",
            "email": "felipesauer11@hotmail.com",
            "homepage": "https://github.com/felipesauer"
        }
    ],
    "support": {
        "issues": "https://github.com/felipesauer/safeaccess-identum/issues",
        "source": "https://github.com/felipesauer/safeaccess-identum/tree/main/packages/php"
    },
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "infection/infection": "^0.32.6"
    },
    "autoload": {
        "psr-4": {
            "SafeAccess\\Identum\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SafeAccess\\Identum\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest --bail --profile --coverage --strict-coverage --min=100",
        "test:coverage": "php -d pcov.enabled=1 vendor/bin/pest --bail --profile --coverage --strict-coverage --min=100",
        "test:mutation": "bash scripts/mutation.sh",
        "test:parity": "vendor/bin/pest tests/Unit/ParityTest.php",
        "analyse": "phpstan analyse",
        "format": "php-cs-fixer fix"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/felipesauer"
        }
    ],
    "minimum-stability": "alpha",
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "infection/extension-installer": true
        }
    }
}
